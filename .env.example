PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
# For EC2/direct IP deployment, use:
# NEXT_PUBLIC_API_URL=http://your-ec2-public-ip:3001
# NEXT_PUBLIC_SOCKET_URL=http://your-ec2-public-ip:3001
# CORS_ORIGINS=http://your-ec2-public-ip:3000
CORS_ORIGINS=http://localhost:3000
DASHBOARD_API_TOKEN=change_this_local_token
NEXT_PUBLIC_DASHBOARD_API_TOKEN=change_this_local_token
AI_PROVIDER=groq
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Personal Chat
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# Keep WhatsApp auth outside the repo and outside disposable temp storage.
# Windows example: C:\\tmp\\vr-2-runtime
# Linux/EC2 example: /home/ubuntu/vr-2-runtime
WWEBJS_DATA_ROOT=/home/ubuntu/vr-2-runtime
