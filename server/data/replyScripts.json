
{
  "settings": {
    "bot_name": "Riya",
    "owner_name": "Vicky",
    "typing_delay_ms": [1000, 4000],
    "reply_chance": 85,
    "cooldown_seconds": 25,
    "avoid_same_reply": true,
    "ignore_groups": true,
    "ignore_status": true,
    "human_typing": true,
    "max_replies_per_chat": 6
  },

  "style_rules": {
    "short_replies": true,
    "casual_tone": true,
    "light_tanglish": true,
    "no_formal_english": true,
    "no_long_paragraphs": true,
    "human_like_only": true,
    "max_lines": 1
  },

  "first_message": {
    "enabled": true,
    "once_per_chat": true,
    "replies": [
      "I'm Riya 😄 Vicky's assistant. Sollunga?",
      "Hey! I'm Riya, Vicky's assistant. Enna help Venu?"
    ]
  },

  "greeting": {
    "enabled": true,
    "keywords": [
      "hi",
      "hello",
      "hey",
      "hii",
      "hai",
      "yo",
      "bro",
      "macha",
      "vanakkam"
    ],
    "replies": [
      "Hey 😄",
      "Hi sollunga.",
      "Enna bro?"
    ]
  },

  "ask_vicky": {
    "enabled": true,
    "keywords": [
      "vicky",
      "boss",
      "enga",
      "online",
      "reply",
      "where",
      "what doing",
      "busy"
    ],
    "replies": [
      "Boss sleeping 😴",
      "Busy with work now.",
      "He’ll reply once free 😄",
      "Outside poirukaaru.",
      "Work panraaru 😭"
    ]
  },

  "money_replies": {
    "enabled": true,
    "keywords": [
      "money",
      "cash",
      "loan",
      "salary",
      "1000",
      "help",
      "amount"
    ],
    "replies": [
      "Boss kidney sell panna dhan possible 😂",
      "Naane innum salary vaangala 💀"
    ]
  },

  "availability": {
    "enabled": true,
    "keywords": [
      "free",
      "available",
      "call",
      "busy",
      "iruka",
      "call panlama"
    ],
    "replies": [
      "Sollunga 😄",
      "Free dhan.",
      "Little busy now."
